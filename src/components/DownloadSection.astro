---
interface Props {
  lang: 'de' | 'en';
  data: {
    eyebrow: string;
    headline: string;
    subheadline: string;
    waitlistLabel: string;
    emailPlaceholder: string;
    submitLabel: string;
    successMessage: string;
    errorMessage: string;
  };
}

const { lang, data } = Astro.props;
---

<section id="download" class="py-28 text-center">
  <div class="max-w-[640px] mx-auto px-8">
    <span class="reveal font-mono text-[0.6875rem] tracking-[0.2em] uppercase text-primary block mb-6">
      {data.eyebrow}
    </span>

    <h2 class="reveal reveal-delay-1 font-display text-[clamp(1.75rem,4vw,2.75rem)] font-bold tracking-tight leading-[1.15] text-foreground mb-4 whitespace-pre-line">
      {data.headline}
    </h2>

    <p class="reveal reveal-delay-2 text-lg text-text2 font-light leading-[1.7] mb-12">
      {data.subheadline}
    </p>

    <!-- Waitlist form (Netlify Forms) -->
    <div class="reveal reveal-delay-3 max-w-[420px] mx-auto">
      <p class="font-mono text-xs tracking-[0.12em] uppercase text-text2 mb-4">
        {data.waitlistLabel}
      </p>

      <form
        id="waitlist-form"
        name="waitlist"
        method="POST"
        data-netlify="true"
        data-netlify-honeypot="bot-field"
        class="flex flex-col sm:flex-row gap-2"
      >
        <input type="hidden" name="form-name" value="waitlist" />
        <input type="hidden" name="lang" value={lang} />
        <!-- Honeypot -->
        <p class="hidden">
          <input name="bot-field" />
        </p>

        <input
          type="email"
          name="email"
          placeholder={data.emailPlaceholder}
          required
          class="flex-1 bg-surface2 border border-border rounded-md px-4 py-3.5 font-body text-[0.9375rem] text-foreground outline-none focus:border-teal-border focus:bg-surface3 transition-colors placeholder:text-text3"
        />
        <button
          type="submit"
          class="bg-primary text-primary-foreground px-6 py-3.5 rounded-md font-mono text-[0.8125rem] tracking-[0.1em] uppercase border-none cursor-pointer transition-all hover:-translate-y-0.5 hover:shadow-[0_8px_32px_hsl(var(--primary)/0.35)] disabled:opacity-50 disabled:cursor-not-allowed"
        >
          {data.submitLabel}
        </button>
      </form>

      <p id="waitlist-success" class="hidden font-mono text-sm text-safe mt-3">
        ✓ {data.successMessage}
      </p>
      <p id="waitlist-error" class="hidden font-mono text-xs text-destructive mt-2">
        {data.errorMessage}
      </p>
    </div>
  </div>
</section>

<script src="/scripts/waitlist.js" defer></script>

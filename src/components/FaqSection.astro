---
interface FaqBullet {
  title: string;
  body: string;
}

interface FaqItem {
  q: string;
  a: string;
  bullets: FaqBullet[] | null;
  a2?: string | null;
  bullets2?: FaqBullet[] | null;
}

interface Props {
  data: {
    eyebrow: string;
    headline: string;
    items: FaqItem[];
  };
  lang?: 'de' | 'en';
}

const { data, lang = 'de' } = Astro.props;
---

<section id="faq" class="bg-background border-b border-border py-24">
  <div class="max-w-content mx-auto px-8">

    <!-- Header -->
    <div class="mb-14">
      <span class="reveal font-mono text-[0.6875rem] tracking-[0.2em] uppercase text-primary block mb-5">
        {data.eyebrow}
      </span>
      <h2 class="reveal reveal-delay-1 font-display text-[clamp(1.75rem,4vw,2.5rem)] font-bold tracking-tight leading-[1.15] text-foreground whitespace-pre-line">
        {data.headline}
      </h2>
    </div>

    <!-- Accordion -->
    <div class="faq-list reveal reveal-delay-2 border-t border-border">
      {data.items.map((item, i) => (
        <details class="faq-item border-b border-border">

          <summary class="faq-summary relative flex items-start justify-between gap-6 py-6 cursor-pointer list-none select-none">
            <!-- Hover underline sweep -->
            <span class="faq-sweep"></span>
            <span class="faq-q font-display text-[1.0625rem] font-semibold text-foreground leading-snug flex-1 pr-4 transition-colors duration-200">
              {item.q}
            </span>
            <!-- Icon circle -->
            <span class="faq-icon relative flex-shrink-0 mt-[0.15em] w-[1.375rem] h-[1.375rem] rounded-full border border-border flex items-center justify-center text-primary transition-all duration-250">
              <svg class="w-[0.625rem] h-[0.625rem]" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg">
                <line x1="6" y1="1" x2="6" y2="11" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
                <line class="faq-hbar" x1="1" y1="6" x2="11" y2="6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
              </svg>
            </span>
          </summary>

          <!-- Max-height wrapper (JS-controlled) -->
          <div class="faq-body overflow-hidden" style="max-height: 0;">
            <!-- Inner: fade + slide -->
            <div class="faq-inner pb-7 pr-12">

              <p class="faq-answer-text text-[0.9375rem] text-text2 leading-7">
                {item.a}
              </p>

              {item.bullets && item.bullets.length > 0 && (
                <ul class="mt-5 flex flex-col gap-4">
                  {item.bullets.map((bullet, bi) => (
                    <li class="faq-bullet flex gap-5 items-start" style={`--bi: ${bi}`}>
                      <span class="flex-shrink-0 mt-[0.4em] w-[2px] h-[1rem] rounded-full bg-primary opacity-60"></span>
                      <div>
                        <p class="text-[0.9375rem] font-semibold text-foreground leading-snug mb-1">
                          {bullet.title}
                        </p>
                        <p class="text-[0.9375rem] text-text2 leading-7">
                          {bullet.body}
                        </p>
                      </div>
                    </li>
                  ))}
                </ul>
              )}

              {item.a2 && (
                <p class="faq-bullet text-[0.9375rem] text-text2 leading-7 mt-6" style="--bi: 2">
                  {item.a2}
                </p>
              )}

              {item.bullets2 && item.bullets2.length > 0 && (
                <ul class="mt-4 flex flex-col gap-4">
                  {item.bullets2.map((bullet, bi) => (
                    <li class="faq-bullet flex gap-5 items-start" style={`--bi: ${bi + 3}`}>
                      <span class="flex-shrink-0 mt-[0.4em] w-[2px] h-[1rem] rounded-full bg-primary opacity-40"></span>
                      <div>
                        <p class="text-[0.9375rem] font-semibold text-foreground leading-snug mb-1">
                          {bullet.title}
                        </p>
                        <p class="text-[0.9375rem] text-text2 leading-7">
                          {bullet.body}
                        </p>
                      </div>
                    </li>
                  ))}
                </ul>
              )}

            </div>
          </div>

        </details>
      ))}
    </div>

  </div>
</section>

<!-- FAQ Schema.org JSON-LD for SEO -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": data.items.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.a + (item.bullets ? ' ' + item.bullets.map(b => b.title + ': ' + b.body).join(' ') : '')
    }
  }))
})} />

<style>
  /* ── Marker reset ── */
  .faq-summary::-webkit-details-marker { display: none; }
  .faq-summary::marker { display: none; }

  /* ── Hover sweep underline ── */
  .faq-sweep {
    position: absolute;
    bottom: 0;
    left: 0;
    height: 1px;
    width: 0;
    background: hsl(var(--primary) / 0.25);
    transition: width 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events: none;
  }
  .faq-summary:hover .faq-sweep { width: 100%; }

  /* ── Question text colour on hover ── */
  .faq-summary:hover .faq-q { color: hsl(var(--foreground)); }

  /* ── Icon: hover state ── */
  .faq-summary:hover .faq-icon {
    border-color: hsl(var(--primary) / 0.45);
    background-color: hsl(var(--primary) / 0.07);
    color: hsl(var(--primary));
  }

  /* ── Icon: open state ── */
  .faq-item[open] .faq-icon {
    border-color: hsl(var(--primary) / 0.55);
    background-color: hsl(var(--primary) / 0.1);
    color: hsl(var(--primary));
  }

  /* ── Horizontal bar morphs away on open ── */
  .faq-hbar {
    transform-origin: center;
    transition: transform 0.28s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.22s ease;
  }
  .faq-item[open] .faq-hbar {
    transform: scaleX(0);
    opacity: 0;
  }

  /* ── Vertical bar subtle scale on open ── */
  .faq-item[open] svg line:first-child {
    transform-origin: center;
    animation: vbar-in 0.28s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  }
  @keyframes vbar-in {
    0%   { transform: scaleY(0.6); }
    100% { transform: scaleY(1); }
  }

  /* ── Max-height accordion ── */
  .faq-body {
    transition: max-height 0.38s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* ── Inner content: fade + slide up on reveal ── */
  .faq-inner {
    opacity: 0;
    transform: translateY(7px);
    transition: opacity 0.28s ease 0.06s, transform 0.32s ease 0.06s;
  }
  .faq-item[open] .faq-inner {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── Bullets: staggered slide-up ── */
  .faq-bullet {
    opacity: 0;
    transform: translateY(5px);
    transition: opacity 0.24s ease, transform 0.28s ease;
    transition-delay: calc(0.1s + var(--bi, 0) * 0.08s);
  }
  .faq-item[open] .faq-bullet {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── Left border accent: grows on open ── */
  .faq-item {
    position: relative;
    transition: background-color 0.2s ease;
  }
  .faq-item::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 2px;
    background: hsl(var(--primary));
    transform: scaleY(0);
    transform-origin: top center;
    transition: transform 0.36s cubic-bezier(0.16, 1, 0.3, 1);
    border-radius: 0 0 1px 1px;
  }
  .faq-item[open]::before { transform: scaleY(1); }
</style>

<script is:inline>
  (function () {
    function initFaq() {
      var items = document.querySelectorAll('.faq-item');

      items.forEach(function (details) {
        var summary = details.querySelector('.faq-summary');
        var body    = details.querySelector('.faq-body');
        if (!summary || !body) return;

        summary.addEventListener('click', function (e) {
          e.preventDefault();

          if (details.open) {
            /* ── Close ── */
            body.style.maxHeight = body.scrollHeight + 'px';
            requestAnimationFrame(function () {
              body.style.maxHeight = '0';
              body.addEventListener('transitionend', function h() {
                details.removeAttribute('open');
                body.removeEventListener('transitionend', h);
              });
            });

          } else {
            /* ── Close any other open item ── */
            items.forEach(function (other) {
              if (other !== details && other.open) {
                var ob = other.querySelector('.faq-body');
                if (ob) {
                  ob.style.maxHeight = ob.scrollHeight + 'px';
                  requestAnimationFrame(function () {
                    ob.style.maxHeight = '0';
                    ob.addEventListener('transitionend', function h() {
                      other.removeAttribute('open');
                      ob.removeEventListener('transitionend', h);
                    });
                  });
                }
              }
            });

            /* ── Open ── */
            details.setAttribute('open', '');
            body.style.maxHeight = '0';
            requestAnimationFrame(function () {
              body.style.maxHeight = body.scrollHeight + 'px';
              body.addEventListener('transitionend', function h() {
                body.style.maxHeight = 'none';
                body.removeEventListener('transitionend', h);
              });
            });
          }
        });
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initFaq);
    } else {
      initFaq();
    }
  })();
</script>

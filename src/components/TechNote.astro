---
interface TechItem {
  icon: string;
  title: string;
  desc: string;
}

interface Props {
  data: {
    items: TechItem[];
  };
}

const { data } = Astro.props;
---

<section class="bg-card border-y border-border py-16">
  <div class="max-w-wide mx-auto px-8">
    <div class="reveal grid grid-cols-1 md:grid-cols-3 border border-border rounded-lg overflow-hidden">
      {data.items.map((item, i) => (
        <div
          class={`p-8 flex flex-col gap-3 ${i < data.items.length - 1 ? 'md:border-r border-b md:border-b-0 border-border' : ''}`}
        >
          <span class="text-xl leading-none">{item.icon}</span>
          <span class="font-display text-[0.9375rem] font-semibold text-foreground">
            {item.title}
          </span>
          <p class="text-sm text-text2 leading-relaxed">
            {item.desc}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>

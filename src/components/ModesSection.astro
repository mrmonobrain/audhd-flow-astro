---
interface ModeItem {
  color: string;
  dotColor: string;
  badge: string;
  name: string;
  hz: string;
  desc: string;
  wide: boolean;
}

interface Props {
  data: {
    eyebrow: string;
    headline: string;
    items: ModeItem[];
  };
}

const { data } = Astro.props;

const gradientMap: Record<string, string> = {
  grey: "from-[#888] to-transparent",
  blue: "from-[#5B9BD5] to-transparent",
  teal: "from-primary to-transparent",
  green: "from-safe to-transparent",
  brown: "from-[#8B6A50] to-transparent",
  rose: "from-[#C46A8A] to-transparent",
};
---

<section id="modes" class="py-28">
  <div class="max-w-wide mx-auto px-8">
    <div class="text-center mb-16">
      <span class="reveal font-mono text-[0.6875rem] tracking-[0.2em] uppercase text-primary block mb-4">
        {data.eyebrow}
      </span>
      <h2 class="reveal reveal-delay-1 font-display text-[clamp(1.75rem,4vw,2.75rem)] font-bold tracking-tight leading-[1.15] text-foreground">
        {data.headline}
      </h2>
    </div>

    <div class="reveal reveal-delay-2 grid grid-cols-1 md:grid-cols-3 gap-px bg-border border border-border rounded-lg overflow-hidden">
      {data.items.map((mode) => (
        <div
          class={`bg-card p-10 md:p-8 relative group cursor-default flex flex-col gap-4 hover:bg-surface2 transition-colors ${mode.wide ? 'md:col-span-3' : ''}`}
        >
          <div class={`absolute top-0 left-0 right-0 h-0.5 bg-gradient-to-r ${gradientMap[mode.color] ?? 'from-primary to-transparent'} opacity-0 group-hover:opacity-100 transition-opacity`}></div>

          <div class="flex items-center gap-2 font-mono text-[0.5625rem] tracking-[0.15em] uppercase text-text3">
            <span class="w-1.5 h-1.5 rounded-full shrink-0" style={`background: ${mode.dotColor}`}></span>
            {mode.badge}
          </div>

          <div class="font-display text-[1.0625rem] font-bold tracking-[0.12em] uppercase text-foreground">
            {mode.name}
          </div>

          <div class="font-mono text-[0.6875rem] text-text3 tracking-[0.05em]">
            {mode.hz}
          </div>

          <p class="text-[0.9375rem] text-text2 leading-relaxed font-light">
            {mode.desc}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>

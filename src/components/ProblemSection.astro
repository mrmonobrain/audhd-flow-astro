---
interface Stat {
  number: string;
  text: string;
}

interface Props {
  data: {
    eyebrow: string;
    headline: string;
    body1: string;
    body2: string;
    quote: string;
    stats: Stat[];
  };
}

const { data } = Astro.props;
---

<section class="bg-card border-y border-border py-28">
  <div class="max-w-wide mx-auto px-8">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-20 items-center">
      <div>
        <span class="reveal font-mono text-[0.6875rem] tracking-[0.2em] uppercase text-primary mb-6 block">
          {data.eyebrow}
        </span>
        <h2 class="reveal reveal-delay-1 font-display text-[clamp(1.75rem,4vw,2.75rem)] font-bold tracking-tight leading-[1.15] text-foreground mb-6">
          {data.headline}
        </h2>
        <p class="reveal reveal-delay-2 text-base leading-[1.75] text-text2 font-light mb-4">
          {data.body1}
        </p>
        <p class="reveal reveal-delay-2 text-base leading-[1.75] text-text2 font-light">
          {data.body2}
        </p>
        <div class="reveal reveal-delay-3 mt-8 pl-6 border-l-2 border-primary bg-[hsl(var(--primary-glow))] rounded-r-md py-5 pr-6">
          <p class="font-mono text-sm italic text-text2 leading-relaxed">
            {data.quote}
          </p>
        </div>
      </div>

      <div class="flex flex-col gap-6">
        {data.stats.map((stat, i) => (
          <div class:list={['reveal relative bg-surface2 border border-border rounded-lg p-7 overflow-hidden hover:border-teal-border transition-colors', i === 0 && 'reveal-delay-1', i === 1 && 'reveal-delay-2', i === 2 && 'reveal-delay-3']}>
            <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-primary to-transparent"></div>
            <div class="font-display text-[2.5rem] font-extrabold text-primary-light leading-none mb-2">
              {stat.number}
            </div>
            <div class="font-mono text-xs tracking-[0.08em] text-text2">
              {stat.text}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

---
interface Props {
  lang: 'de' | 'en';
  global: {
    footer: {
      tagline1De: string;
      tagline1En: string;
      tagline2De: string;
      tagline2En: string;
      impressumDe: string;
      impressumEn: string;
      datenschutzDe: string;
      datenschutzEn: string;
    };
  };
}

const { lang, global } = Astro.props;
const f = global.footer;
const prefix = `/${lang}`;
---

<footer class="border-t border-border py-12 px-8">
  <div class="max-w-content mx-auto flex flex-col md:flex-row items-start md:items-center justify-between gap-8">
    <div class="flex items-center gap-3">
      <img src="/images/logo-audhd_flow-circle.png" alt="AuDHD-Flow" class="w-[22px] h-[22px] rounded-sm" loading="lazy" />
      <span class="font-bold tracking-[0.12em] uppercase text-[0.9375rem]" style="font-family: Menlo, Monaco, 'Courier New', monospace; color: #1a3c34;">
        AuDHD-Flow
      </span>
    </div>

    <div class="flex flex-col gap-1">
      <span class="font-mono text-[0.6875rem] tracking-[0.1em] uppercase text-text3">
        {lang === 'de' ? f.tagline1De : f.tagline1En}
      </span>
      <span class="font-mono text-[0.625rem] tracking-[0.15em] uppercase text-text3">
        {lang === 'de' ? f.tagline2De : f.tagline2En}
      </span>
    </div>

    <div class="flex gap-6">
      <a href={`${prefix}/impressum`} class="font-mono text-[0.6875rem] tracking-[0.1em] uppercase text-text3 hover:text-primary-light transition-colors no-underline">
        {lang === 'de' ? f.impressumDe : f.impressumEn}
      </a>
      <a href={`${prefix}/datenschutz`} class="font-mono text-[0.6875rem] tracking-[0.1em] uppercase text-text3 hover:text-primary-light transition-colors no-underline">
        {lang === 'de' ? f.datenschutzDe : f.datenschutzEn}
      </a>
    </div>
  </div>
</footer>

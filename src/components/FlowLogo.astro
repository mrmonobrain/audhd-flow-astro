---
interface Props {
  class?: string;
}
const { class: className = 'w-7 h-7' } = Astro.props;
---

<svg class={className} viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
  <circle cx="50" cy="50" r="48" stroke="currentColor" stroke-width="1.5" class="text-primary" />
  <circle cx="50" cy="50" r="32" stroke="currentColor" stroke-width="1" class="text-primary" opacity="0.5" />
  <circle cx="50" cy="50" r="16" stroke="currentColor" stroke-width="0.75" class="text-primary" opacity="0.3" />
  <path d="M50 2 C50 2 68 30 68 50 C68 70 50 98 50 98" stroke="currentColor" stroke-width="1" class="text-primary" opacity="0.4" />
  <path d="M50 2 C50 2 32 30 32 50 C32 70 50 98 50 98" stroke="currentColor" stroke-width="1" class="text-primary" opacity="0.4" />
  <line x1="2" y1="50" x2="98" y2="50" stroke="currentColor" stroke-width="0.75" class="text-primary" opacity="0.2" />
</svg>

<html>
<head>
  <meta charset="utf-8">
  <script>
    // Handle Netlify Identity tokens before redirecting
    if (window.location.hash.match(/#(invite|recovery)_token=/)) {
      window.location.href = '/admin/' + window.location.hash;
    } else {
      window.location.href = '/de/';
    }
  </script>
  <meta http-equiv="refresh" content="0;url=/de/">
  <meta name="robots" content="noindex">
</head>
<body>
  <a href="/de/">Redirecting…</a>
</body>
</html>
